{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "indicators.schema.json",
  "title": "CompanyIndicators",
  "description": "Signals/indicators entry for one org — extracted from indicators.json keyed by org ID",
  "type": "object",
  "required": ["name", "external_indicators", "internal_indicators"],
  "properties": {
    "name": { "type": "string" },
    "external_indicators": {
      "type": "array",
      "items": { "$ref": "#/definitions/Indicator" }
    },
    "internal_indicators": {
      "type": "array",
      "items": { "$ref": "#/definitions/Indicator" }
    }
  },
  "definitions": {
    "Indicator": {
      "type": "object",
      "required": ["category", "indicator", "value", "signal", "detail"],
      "properties": {
        "category": { "type": "string" },
        "indicator": { "type": "string" },
        "value": { "type": "string" },
        "signal": {
          "type": "string",
          "enum": ["positive", "negative", "neutral", "watch"]
        },
        "detail": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
