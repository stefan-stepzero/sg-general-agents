{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "competitors.schema.json",
  "title": "CompanyLandscape",
  "description": "Competitive landscape entry for one org — extracted from competitive-landscape.json keyed by org ID",
  "type": "object",
  "required": ["name", "market", "market_size", "position", "position_detail", "advantages", "disadvantages", "competitors", "metrics"],
  "properties": {
    "name": { "type": "string" },
    "market": { "type": "string" },
    "market_size": { "type": "string" },
    "position": { "type": "string" },
    "position_detail": { "type": "string" },
    "advantages": {
      "type": "array",
      "items": { "$ref": "#/definitions/AdvDisadv" }
    },
    "disadvantages": {
      "type": "array",
      "items": { "$ref": "#/definitions/AdvDisadv" }
    },
    "competitors": {
      "type": "array",
      "items": { "$ref": "#/definitions/CompetitorEntry" }
    },
    "metrics": {
      "type": "array",
      "items": { "$ref": "#/definitions/Metric" }
    }
  },
  "definitions": {
    "CompetitorEntry": {
      "type": "object",
      "required": ["name", "positioning", "differentiation", "relationship"],
      "properties": {
        "name": { "type": "string" },
        "positioning": { "type": "string" },
        "differentiation": {
          "type": "string",
          "description": "Single string. NOTE: must NOT be an array — join with ' | ' if needed"
        },
        "relationship": { "type": "string" }
      },
      "additionalProperties": true
    },
    "AdvDisadv": {
      "type": "object",
      "required": ["label", "detail"],
      "properties": {
        "label": { "type": "string" },
        "detail": { "type": "string" }
      }
    },
    "Metric": {
      "type": "object",
      "required": ["label", "value", "context"],
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "string" },
        "context": { "type": "string" }
      }
    }
  },
  "additionalProperties": true
}
